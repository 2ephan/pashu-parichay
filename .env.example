# Copy this file to `.env.local` and fill in your key (required for Gemini: scanner, chat, breed details).
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional Vite-prefixed alias (either one is accepted):
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override YOLO API base (default `/api` — Vite proxies to localhost:8000 in dev).
# VITE_YOLO_API_BASE=http://127.0.0.1:8000

# Optional (Python server only): max upload size in MB for /segment (default 8).
# YOLO_MAX_UPLOAD_MB=8

# Optional (Python server only): path to Ultralytics weights (default: model/best.pt next to server.py).
# YOLO_WEIGHTS=/absolute/path/to/best.pt
