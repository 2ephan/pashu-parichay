{
  "name": "pashuparichay---ai-cattle-breed-recognition",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:yolo": "python model/server.py",
    "dev:stack": "concurrently -n web,yolo -c cyan,magenta \"vite\" \"npm run dev:yolo\"",
    "setup": "npm install && python -m pip install -r model/requirements.txt",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "doctor": "npm run lint && npm run build",
    "one-click": "npm run setup && npm run dev:stack"
  },
  "dependencies": {
    "@google/genai": "^1.39.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
